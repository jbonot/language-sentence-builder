# Copy to .env for local overrides. Not loaded in production on Railway —
# set these as actual environment variables in the Railway service instead.

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# True for local development, False (or unset) in production
DEBUG=True

# Comma-separated. Railway's own domain is added automatically via RAILWAY_PUBLIC_DOMAIN.
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated, must include scheme (https://...). Required for local dev
# too now: any authenticated (session-cookie) POST/PATCH/DELETE request is
# CSRF-checked against this list, so it must include the frontend's origin,
# e.g. http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Comma-separated origins of the deployed frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set automatically by Railway's Postgres plugin when linked; leave unset
# locally to fall back to the docker-compose database.
DATABASE_URL=
